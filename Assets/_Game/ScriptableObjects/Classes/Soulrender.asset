  m_Name: Soulrender
  m_EditorClassIdentifier: 
  classId: 1
  displayName: Soulrender
  emoji: "\U0001FA78"
  characterKey: Soulrender
  lore: "Les Soulrenders sont les h\xE9ritiers d'un pacte de guerre oubli\xE9, o\xF9
    le sang a cess\xE9 d'\xEAtre un fluide vital pour devenir une arme brute.\n\nN\xE9s
    dans les ar\xE8nes de souffrance, ils ne connaissent la paix que dans l'h\xE9morragie.\n\nUne
    atmosph\xE8re de fer rouill\xE9 et de vapeur chaude. Leur pr\xE9sence sature
    l'air d'une odeur de cuivre et du son sourd d'un c\u0153ur qui tambourine contre
    la r\xE9alit\xE9. Des silhouettes nerveuses entour\xE9es d'une brume rouge pixelis\xE9e
    qui semble s'\xE9chapper de leurs pores comme une sueur \xE9carlate."
  passiveName: "Vol d'\xC2me"
  passiveMechanic: "+1 jauge par 60 d\xE9g\xE2ts inflig\xE9s. Chaque palier augmente
    le bonus de d\xE9g\xE2ts et acc\xE9l\xE8re la mont\xE9e de jauge."
  stageBase:
    label: Base
    jaugeMin: 0
    jaugeMax: 2
    effectDescription: "+5% d\xE9g\xE2ts."
  stageEveille:
    label: "\xC9veill\xE9"
    jaugeMin: 3
    jaugeMax: 5
    effectDescription: "+10% d\xE9g\xE2ts."
  stageEnrage:
    label: "Enrag\xE9"
    jaugeMin: 6
    jaugeMax: -1
    effectDescription: "+20% d\xE9g\xE2ts. D\xE9bloque \xC2me Lac\xE9r\xE9e."
  enragedSpellName: "\xC2me Lac\xE9r\xE9e"
  enragedSpellDescription: "1 PA \u2014 Port\xE9e 1 \u2014 180 d\xE9g\xE2ts. Le lanceur
    r\xE9cup\xE8re 90 HP."
