  m_Script: {fileID: 11500000, guid: 8b41657a3055ca044895352d380bfbc7, type: 3}
  m_Name: Necram
  m_EditorClassIdentifier: 
  classId: 4
  displayName: Necram
  emoji: "\u2620\uFE0F"
  lore: "Pour cette race, la vie n'est qu'une infection temporaire. Ils se voient
    comme les jardiniers d'une d\xE9composition sacr\xE9e.\n\nIssus des marais de
    putr\xE9faction, ils ont troqu\xE9 leur humanit\xE9 contre la symbiose avec des
    parasites ancestraux.\n\nUne ambiance de bourdonnement incessant et de pourriture
    fertile. Leur monde est celui des spores vertes, des moisissures rampantes et
    des r\xE2les d'agonie \xE9touff\xE9s. Des silhouettes vo\xFBt\xE9es, presque
    organiques, drap\xE9es dans un nuage toxique dense o\xF9 s'agitent des milliers
    de mouches pixelis\xE9es."
  passiveName: Toxine
  passiveMechanic: "+1 jauge par marque de Venin appliqu\xE9e. Chaque sort offensif
    applique des marques qui tick des d\xE9g\xE2ts par tour (stack infini). Les DoT
    de Venin ignorent la r\xE9duction de d\xE9g\xE2ts du Colossar."
  stageBase:
    label: Base
    jaugeMin: 0
    jaugeMax: 3
    effectDescription: "Chaque sort offensif applique 1 marque (22 dmg/tour \xD7
      3 tours, stack infini)."
  stageEveille:
    label: "\xC9veill\xE9"
    jaugeMin: 4
    jaugeMax: 6
    effectDescription: "+15% d\xE9g\xE2ts DoT venin (ticks 22\u219225). Regen 1 HP/marque.
      +2 jauges/marque."
  stageEnrage:
    label: "Enrag\xE9"
    jaugeMin: 7
    jaugeMax: -1
    effectDescription: "+30% d\xE9g\xE2ts DoT venin (ticks 22\u219229). D\xE9bloque
      Virus Fatal."
  enragedSpellName: Virus Fatal
  enragedSpellDescription: "1 PA \u2014 Port\xE9e 3 \u2014 D\xE9clenche imm\xE9diatement
    toutes les marques sur la cible (avec multiplicateur Enrag\xE9) puis les retire."
  enragedSpell: {fileID: 11400000, guid: 5416f10f38d63044bbeace689a56a0cd, type: 2}
